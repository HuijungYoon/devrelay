{
  "name": "redmine-devrelay-client",
  "version": "0.6.0",
  "description": "Redmine REST client for redmine-devrelay MCP ??auth, pagination, issue read/write helpers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.ko.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HuijungYoon/devrelay.git",
    "directory": "packages/redmine-client"
  },
  "homepage": "https://github.com/HuijungYoon/devrelay#readme",
  "bugs": {
    "url": "https://github.com/HuijungYoon/devrelay/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "redmine",
    "rest",
    "api",
    "devrelay",
    "mcp"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "typescript": "5.8.2",
    "vitest": "3.0.9"
  },
  "dependencies": {
    "undici": "7.8.0"
  }
}
