{
  "name": "redmine-devrelay",
  "version": "0.1.0",
  "description": "Read-only Redmine MCP server (DevRelay) — test connection, list projects, search/get issues",
  "type": "module",
  "bin": {
    "redmine-devrelay": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "redmine",
    "mcp",
    "model-context-protocol",
    "cursor",
    "devrelay"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "redmine-devrelay-client": "workspace:*",
    "@modelcontextprotocol/sdk": "1.12.1",
    "zod": "3.25.28"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "typescript": "5.8.2",
    "vitest": "3.0.9"
  }
}
