{
  "name": "redmine-devrelay",
  "version": "0.2.4",
  "description": "Redmine MCP server for Cursor/Claude/Codex — read issues and create/comment/update with confirm gate (DevRelay)",
  "type": "module",
  "bin": {
    "redmine-devrelay": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HuijungYoon/devrelay.git",
    "directory": "packages/redmine-mcp"
  },
  "homepage": "https://github.com/HuijungYoon/devrelay#readme",
  "bugs": {
    "url": "https://github.com/HuijungYoon/devrelay/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "redmine",
    "mcp",
    "model-context-protocol",
    "cursor",
    "devrelay"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "redmine-devrelay-client": "workspace:*",
    "@modelcontextprotocol/sdk": "1.12.1",
    "zod": "3.25.28"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "typescript": "5.8.2",
    "vitest": "3.0.9"
  }
}
